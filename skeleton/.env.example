# Cinder 环境变量示例
# 复制为 .env，填入实际值。.env 已在 .gitignore 中。

# ============================================================
# Claude Code CLI（必填）
# ============================================================

# Anthropic API Base URL
# - 官方：https://api.anthropic.com
# - 三方中转：https://your-provider.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com

# API Token（三方中转时用 ANTHROPIC_AUTH_TOKEN，官方用 ANTHROPIC_API_KEY 也行）
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxx

# 默认 model（按你三方厂商支持的列表填）
DEFAULT_MODEL=claude-sonnet-4-6

# ============================================================
# CINDER 仓根（A1 + hook 用，可选）
# ============================================================
# 三层 fallback：env > ~/.cinder/config > 脚本位置推导
# 不填也能跑（脚本会从自身位置推导仓根）
# CINDER_HOME=/Users/yourname/path/to/cinder

# ============================================================
# 飞书 bot 子进程（仅接飞书时用）
# ============================================================

# Claude subprocess 代理（国内三方 API 直连必须设空，否则走错链路）
CLAUDE_SUBPROCESS_PROXY=

# 飞书 bot 凭证（接飞书才填，详见 docs/02-feishu-bot.md）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=
# ADMIN_OPEN_IDS=
