# Cinder Starter .env 模板
# 用法：
#   1. cp skeleton/.env.example .env
#   2. 只改下面标了“必填”的 2-3 个字段
#   3. 不要提交 .env（仓库 .gitignore 已忽略）
#
# 最小可用配置：ANTHROPIC_BASE_URL + ANTHROPIC_AUTH_TOKEN + DEFAULT_MODEL。

# ============================================================
# Claude Code CLI（必填）
# ============================================================

# Anthropic 兼容 API Base URL（必填）
# - 官方：https://api.anthropic.com
# - 三方中转：https://your-provider.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com

# API Token（必填）
# - 三方中转：通常填 ANTHROPIC_AUTH_TOKEN
# - 官方 Anthropic：也可以改用 ANTHROPIC_API_KEY
ANTHROPIC_AUTH_TOKEN=sk-REPLACE_ME
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# 默认模型（必填，按你的供应商支持列表填）
# 推荐：日常协作 Sonnet；便宜批处理/评分 Haiku。
DEFAULT_MODEL=claude-sonnet-4-6

# A1 自动评分模型（可选）
# 留空时使用工具默认值；供应商不支持默认 Haiku 时再打开并改成可用模型。
# CINDER_A1_SCORE_MODEL=claude-haiku-4-5

# ============================================================
# Cinder 仓根（推荐）
# ============================================================

# A1 / hook 解析仓根使用。bootstrap 脚本会写 ~/.cinder/config；
# 手动配置时可取消注释并改成你的仓库绝对路径。
# CINDER_HOME=/Users/yourname/path/to/cinder

# ============================================================
# Claude Code 行为开关（可选）
# ============================================================

# 需要更详细 CLI 日志时打开。
# ANTHROPIC_LOG=debug

# 如果你的三方服务要求额外 header，可按供应商文档设置。
# ANTHROPIC_CUSTOM_HEADERS=

# ============================================================
# 飞书 bot 子进程（仅接飞书时填写）
# ============================================================

# Claude subprocess 代理（国内三方 API 直连必须设空，否则走错链路）
CLAUDE_SUBPROCESS_PROXY=

# 飞书 bot 凭证（接飞书才填，详见 docs/02-feishu-bot.md）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=
# ADMIN_OPEN_IDS=

# 双模型路由 + 上下文压缩（可选进阶，详见 docs/02-feishu-bot.md §七）
# 用智谱 GLM 作 bot 主控时填；ANTHROPIC_AUTH_TOKEN 留给 claude-* 端点
# ZHIPU_CODING_TOKEN=REPLACE_ME
# COMPRESS_THRESHOLD_TOKENS=40000

# ============================================================
# 安全提醒
# ============================================================
# 不要把以下内容提交到公开仓：
# - .env / token / API key
# - brain/self/（私人画像）
# - vault/（原始档案）
