{
  "_comment": "复制本文件为 settings.local.json，把 <主项目根> 替换成你的绝对路径",
  "permissions": {
    "defaultMode": "denyAll",
    "allow": [
      "Read",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(lark:*)",
      "Bash(pbpaste:*)",
      "Bash(pbcopy:*)",
      "Bash(jq:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "WebSearch",
      "WebFetch",
      "Write(./scratch/**)",
      "Write(./inbox/**)",
      "Write(<主项目根>/brain/workspace/**)",
      "Write(<主项目根>/brain/inbox/*.im.md)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git merge:*)",
      "Bash(npm install:*)",
      "Bash(pip install:*)",
      "Bash(brew install:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.lark-cli/**)",
      "Read(~/.openclaw/**)",
      "Read(~/.claude/**)",
      "Write(<主项目根>/brain/cortex/**/_context.md)",
      "Write(<主项目根>/brain/cortex/methodology.md)",
      "Write(<主项目根>/brain/gateway.md)",
      "Write(<主项目根>/brain/concepts/**)",
      "Write(<主项目根>/brain/views/**)",
      "Write(<主项目根>/brain/self/**)",
      "Write(<主项目根>/brain/timeline/**)",
      "Write(<主项目根>/brain/archive/**)",
      "Write(<主项目根>/vault/**)",
      "Write(<主项目根>/CLAUDE.md)"
    ]
  }
}
